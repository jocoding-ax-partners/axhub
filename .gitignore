# Build outputs. Keep the committed bootstrap shim, ignore native release builds.
bin/axhub-helpers
!bin/axhub-helpers
bin/axhub-helpers-*
dist/
*.exe

# Node / Bun
node_modules/
.bun/
bun.lockb
package-lock.json
yarn.lock

# OS
.DS_Store
Thumbs.db

# IDE / editors
.vscode/
.idea/
*.swp
*.swo

# Logs and runtime state
*.log
.cache/
~/.cache/axhub-plugin/

# Test artifacts
tests/.coverage/
tests/.last-run/

# OMC / orchestration state (per-session, transient — not for commit)
.omc/state/
.omc/sessions/
.omc/logs/
.omc/plans/*.md
.omx/

# Autoplan restore points (transient)
.autoplan/

# Graphify output (local knowledge graph, large)
graphify-out/

# Project memory / notepad (local context only)
.omc/project-memory.json
.omc/notepad.md

# Local Claude config (per-developer plugin/skill setup, not project artifact)
.claude/

# Transient harness state
docs/.harness-state.json

# GitNexus index
.gitnexus

# Rust build outputs
target/

# Plan documents (local strategic notes, not for commit)
.plan/
test-results.json

# Test runtime tmp dirs (afterAll cleanup may miss on test interrupt)
tests/.tmp-*/
.codegraph/

# axhub quality auto-mode runtime state (session-local, not for commit)
.axhub-state/
.axhub/init-resume.json
.axhub/scaffold-dev.json
.axhub/scaffold-dev.log
