#!/usr/bin/env bash
# Phase 22.0.4 / 22.1 — fixture axhub shim.
# Sentinel touch + current CLI-surface stub.
# 시스템 /usr/local/bin/axhub 호출 0건 검증용 — sentinel 없으면 leak 발생.
#
# Phase 22.4 확장 — env-driven stub 분기:
#   AXHUB_FIXTURE_VERSION=X.Y.Z   --version 응답 가짜 버전 (cli_too_old/cli_too_new 강제)
#   AXHUB_FIXTURE_AUTH=expired    auth status / deploy create 모두 exit 65 + token_expired stderr
#   AXHUB_FIXTURE_AUTH=deploy_expired auth status / preflight 는 통과, deploy create /
#                                 plugin-support deploy-approved-run / token-gate 만 exit 65 + token_expired stderr
#
# Post-diet 확장 — plugin-support 명령 family:
#   plugin-support preflight [--json]        cli_present/cli_state/in_range + auth_ok=true (deploy_expired 도 true).
#   plugin-support route-decision [...]      {"decision":"axhub"} (fail-open 정상 경로).
#   plugin-support tenant-resolve [--json]   빈 tenant + needs_pick=false.
#   plugin-support deploy-prep --intent ...  preflight/resolve/quality_gate envelope, exit_code 0.
#   plugin-support deploy-preview-summary    한국어 preview text (해요체).
#   plugin-support deploy-approved-run        deploy_expired → exit 65 token_expired (저장 토큰이 여기서 만료 판명).
#   plugin-support token-gate                 deploy_expired → exit 65, else exit 0 (stdout 없음).

set -euo pipefail

# Sentinel — assert_shim_used_or_skipped 가 검증.
SHIM_CASE_DIR="${SHIM_CASE_DIR:-${HOME}/.cache/axhub-plugin}"
mkdir -p "$SHIM_CASE_DIR"
touch "${SHIM_CASE_DIR}/shim-called"
printf '%s\n' "$*" >> "${SHIM_CASE_DIR}/axhub-argv.log"

# Forward args to mock-impl 또는 simple stub.
MOCK_IMPL="$(dirname "$0")/axhub-mock-impl.sh"
if [ -x "$MOCK_IMPL" ]; then
  exec "$MOCK_IMPL" "$@"
fi

JSON=0
if [ "${1:-}" = "--json" ]; then
  JSON=1
  shift
fi

# mock-impl 부재 시 simple stub — 부재 subcommand 면 unknown 반환.
case "${1:-}" in
  plugin-support)
    # Post-diet helper family. `axhub plugin-support <cmd> [flags]`.
    PS_CMD="${2:-}"
    case "$PS_CMD" in
      preflight)
        # preflight: token 은 아직 fine (deploy_expired 도 auth_ok=true).
        # raw stderr/exit-jargon 미노출 — JSON contract 만.
        echo '{"cli_present":true,"cli_state":"ok","in_range":true,"cli_too_old":false,"cli_too_new":false,"auth_ok":true,"auth_error_code":null,"profile":"paydrop"}'
        exit 0
        ;;
      route-decision)
        # fail-open 정상 경로 — axhub 배포 확정.
        echo '{"decision":"axhub"}'
        exit 0
        ;;
      tenant-resolve)
        echo '{"tenant":"","source":"","needs_pick":false,"candidates":[]}'
        exit 0
        ;;
      deploy-prep)
        # resolve + preflight 한 번에. auth 는 prep 시점엔 통과 (저장 토큰 만료는 실행 순간 발견).
        echo '{"preflight":{"auth_ok":true,"cli_too_old":false,"cli_too_new":false,"auth_error_code":null},"resolve":{"app_id":"app-123","app_slug":"paydrop","commit_sha":"abc1234","branch":"main","eta_sec":60},"bootstrap_plan":null,"exit_code":0,"preflight_exit_code":0,"in_flight_deploy":null,"github_connected":true,"quality_gate":{"passed":true,"violations":[]}}'
        exit 0
        ;;
      deploy-preview-summary)
        # 5필드 한국어 preview card (해요체). raw 값 미노출.
        echo "다음을 올릴게요: 앱 paydrop / 환경 production / 브랜치 main / 커밋 abc1234 / 예상 약 1분 걸려요."
        exit 0
        ;;
      deploy-approved-run)
        # 승인 직후 실행 — 저장 토큰이 만료된 게 이 순간 드러나요.
        if [ "${AXHUB_FIXTURE_AUTH:-}" = "deploy_expired" ] || [ "${AXHUB_FIXTURE_AUTH:-}" = "expired" ]; then
          echo '{"code":"token_expired","detail":"저장된 토큰이 만료됐어요 (deploy-approved-run)"}' >&2
          exit 65
        fi
        echo "배포를 시작했어요."
        exit 0
        ;;
      token-gate)
        # stdout 없음, exit code 가 계약.
        if [ "${AXHUB_FIXTURE_AUTH:-}" = "deploy_expired" ] || [ "${AXHUB_FIXTURE_AUTH:-}" = "expired" ]; then
          exit 65
        fi
        exit 0
        ;;
      classify-exit)
        # canonical router — helper 65/67/68 → CLI 4/5/6 정규화.
        RAW_EXIT="${3:-0}"
        case "$RAW_EXIT" in
          65) echo '{"exit_code":65,"normalized":4,"category":"auth","message":"token_expired"}' ;;
          67) echo '{"exit_code":67,"normalized":5,"category":"not_found","message":"resource_not_found"}' ;;
          68) echo '{"exit_code":68,"normalized":6,"category":"rate_limit","message":"rate_limited"}' ;;
          *)  echo '{"exit_code":'"${RAW_EXIT}"',"normalized":'"${RAW_EXIT}"',"category":"unknown","message":""}' ;;
        esac
        exit 0
        ;;
      *)
        echo '{"error":"mock_not_implemented","subcommand":"plugin-support '"${PS_CMD}"'"}' >&2
        exit 64
        ;;
    esac
    ;;
  --version)
    if [ -n "${AXHUB_FIXTURE_VERSION:-}" ]; then
      echo "ax-hub-cli ${AXHUB_FIXTURE_VERSION} (commit fake, built fake, fake)"
    else
      echo "ax-hub-cli 0.17.3-mock"
    fi
    exit 0
    ;;
  --help|help)
    echo "Usage: axhub <subcommand> [args]"
    echo "Subcommands: deploy / apps / catalog / auth / update / logs"
    exit 0
    ;;
  auth)
    case "${2:-}" in
      status)
        if [ "${AXHUB_FIXTURE_AUTH:-}" = "expired" ]; then
          echo '{"code":"token_expired","detail":"Bearer token has expired"}' >&2
          exit 65
        fi
        # 기본: unauth (token fixture 없을 때). Match helper token lookup:
        # XDG_CONFIG_HOME/axhub-plugin/token first, not the developer's real HOME.
        TOKEN_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/axhub-plugin/token"
        if [ -f "$TOKEN_PATH" ]; then
          echo '{"user_email":"test@axhub.local","token_expires_at":"2099-01-01T00:00:00Z"}'
        else
          echo '{"error":"not_authenticated"}' >&2
          exit 65
        fi
        ;;
      *)
        echo '{"error":"unknown_subcommand","subcommand":"auth '"${2:-}"'"}' >&2
        exit 64
        ;;
    esac
    ;;
  apps)
    case "${2:-}" in
      list)
        echo '{"apps":[{"id":"app_paydrop","slug":"paydrop","name":"paydrop","env":"prod"}]}'
        ;;
      *)
        echo '{"error":"unknown_subcommand"}' >&2
        exit 64
        ;;
    esac
    ;;
  deploy)
    case "${2:-}" in
      list)
        if [ "${AXHUB_FIXTURE_DEPLOY_LIST_AUTH:-}" = "invalid" ]; then
          # Current axhub CLI auth-error contract (verified vs live 0.17.4):
          # exit 4, flat closed-enum error.code "auth", bare subcode "token_invalid".
          echo '{"schema_version":"1","status":"error","error":{"code":"auth","subcode":"token_invalid","category":"auth","message":"Bearer token is invalid"}}'
          exit 4
        fi
        echo '{"items":[{"id":"dep-fixture","app_id":"paydrop","status":"running","created_at":"2026-05-11T00:00:00Z"}]}'
        ;;
      status)
        echo '{"id":"dep-fixture","status":"live","created_at":"2026-05-11T00:00:00Z"}'
        ;;
      logs)
        echo '{"items":[{"message":"INFO fixture log ready","source":"runtime"}]}'
        ;;
      create)
        if [ "${AXHUB_FIXTURE_AUTH:-}" = "expired" ] || [ "${AXHUB_FIXTURE_AUTH:-}" = "deploy_expired" ]; then
          echo '{"code":"token_expired","detail":"Bearer token has expired during deploy create"}' >&2
          exit 65
        fi
        echo '{"error":"mock_not_implemented","subcommand":"deploy create"}' >&2
        exit 64
        ;;
      *)
        echo '{"error":"mock_not_implemented","subcommand":"deploy '"${2:-}"'"}' >&2
        exit 64
        ;;
    esac
    ;;
  catalog)
    case "${2:-}" in
      resources|search)
        echo '{"items":[{"connector":"paydrop-public","path":"/v1/paydrop/balance","kind":"http-endpoint","description":"balance 조회","app":"paydrop","allowed_actions":["read"]},{"connector":"paydrop-create","path":"/v1/paydrop","kind":"http-endpoint","description":"결제 생성","app":"paydrop","allowed_actions":["read"]}],"next_cursor":null}'
        ;;
      get)
        echo '{"connector":"paydrop-public","path":"/v1/paydrop/balance","kind":"http-endpoint","description":"balance 조회","allowed_actions":["read"]}'
        ;;
      invoke)
        echo '{"error":"mock_not_implemented","subcommand":"catalog invoke"}' >&2
        exit 64
        ;;
      *)
        echo '{"error":"mock_not_implemented","subcommand":"catalog '"${2:-}"'"}' >&2
        exit 64
        ;;
    esac
    ;;
  update)
    case "${2:-}" in
      check)
        echo '{"current":"v0.17.4","latest":"v0.17.4","has_update":false}'
        ;;
      apply)
        echo '{"error":"mock_not_implemented","subcommand":"update apply"}' >&2
        exit 64
        ;;
      *)
        echo '{"error":"mock_not_implemented","subcommand":"update '"${2:-}"'"}' >&2
        exit 64
        ;;
    esac
    ;;
  logs)
    echo '{"error":"mock_not_implemented","subcommand":"'"$1"' '"${2:-}"'"}' >&2
    exit 64
    ;;
  *)
    echo "shim: unknown command '${1:-}'" >&2
    exit 127
    ;;
esac
