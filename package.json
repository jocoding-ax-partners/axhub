{
  "name": "@jocoding-ax-partners/axhub-plugin-cc",
  "version": "0.9.42",
  "description": "axhub Claude Code plugin — Korean-first NL deploy/manage for vibe coders. Rust helper only (TS shadow removed v0.2.0); Bun for repo tooling.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun scripts/build-rust-helper.ts",
    "build:darwin-arm64": "bun scripts/build-rust-helper.ts --target-alias darwin-arm64",
    "build:darwin-amd64": "bun scripts/build-rust-helper.ts --target-alias darwin-amd64",
    "build:linux-amd64": "bun scripts/build-rust-helper.ts --target-alias linux-amd64",
    "build:linux-arm64": "bun scripts/build-rust-helper.ts --target-alias linux-arm64",
    "build:windows-amd64": "bun scripts/build-rust-helper.ts --target-alias windows-amd64",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-amd64 && bun run build:linux-amd64 && bun run build:linux-arm64 && bun run build:windows-amd64",
    "smoke": "bun scripts/smoke.ts",
    "smoke:full": "bun scripts/smoke.ts --full",
    "bench:hooks": "bun scripts/benchmark-hooks.ts",
    "gate:check": "bun run scripts/migration-gate-check.ts",
    "measure:baseline": "bun run scripts/measure-docs-only-baseline.ts",
    "codegen:skill-examples": "bun run scripts/codegen-skill-examples.ts",
    "routing:tune": "bun run scripts/routing-tune.ts",
    "routing:drift": "bun run scripts/routing-drift-check.ts",
    "codegen:catalog": "bun scripts/codegen-catalog.ts",
    "codegen:skill-keywords": "bun scripts/codegen-skill-keywords-from-rust.ts",
    "codegen:version": "bun scripts/codegen-install-version.ts",
    "lint:tone": "bun scripts/check-toss-tone-conformance.ts --strict",
    "lint:keywords": "bun scripts/check-skill-keywords-preserved.ts --check",
    "release:check": "bun scripts/release-check.ts",
    "release": "commit-and-tag-version",
    "release:tag": "bun scripts/release-tag.ts",
    "skill:new": "bun scripts/skill-new.ts",
    "skill:doctor": "bun scripts/skill-doctor.ts",
    "test": "bun test",
    "test:routing": "bun tests/run-corpus.ts --mode plugin --corpus tests/corpus.100.jsonl --vs claude-native --score",
    "test:routing:20": "bun tests/run-corpus.ts --mode plugin --corpus tests/corpus.20.jsonl --vs claude-native --score",
    "test:routing:100": "bun tests/run-corpus.ts --mode plugin --corpus tests/corpus.100.jsonl --vs claude-native --score",
    "test:routing:full": "bun tests/run-corpus.ts --mode plugin --corpus tests/corpus.jsonl --vs claude-native --score",
    "test:e2e": "bun test tests/e2e/",
    "test:plugin-e2e": "bash tests/e2e/claude-cli/run-matrix.sh",
    "test:plugin-e2e:t1": "bash tests/e2e/claude-cli/run-matrix.sh --tier t1",
    "test:plugin-e2e:t2": "bash tests/e2e/claude-cli/run-matrix.sh --tier t2",
    "test:plugin-e2e:nightly": "bash tests/e2e/claude-cli/run-matrix.sh --tier nightly",
    "typecheck": "tsc --noEmit",
    "lint:tone:rust": "bun scripts/check-toss-tone-conformance.ts --include \"crates/**/*.rs\" --strict",
    "cargo:test": "cargo test --workspace",
    "cargo:build": "cargo build --workspace",
    "cargo:coverage": "cargo llvm-cov --workspace --fail-under-lines 84",
    "measure:vibe-bootstrap": "bun scripts/measure-vibe-bootstrap.ts",
    "check:vibe-sla": "bun scripts/check-vibe-bootstrap-sla.ts",
    "agent:new": "bun scripts/codegen-agent-scaffold.ts",
    "eval:megaskill-pilot": "bun scripts/eval-megaskill-pilot.ts",
    "eval:megaskill-final": "bun scripts/eval-megaskill-final.ts",
    "lint:hook-inject": "bun scripts/lint-hook-inject-shape.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "semver": "^7.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/semver": "^7.5.8",
    "commit-and-tag-version": "^12.7.1",
    "typescript": "^5.6.3"
  }
}
