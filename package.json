{
  "name": "@jocoding-ax-partners/axhub-plugin-cc",
  "version": "0.1.24",
  "description": "axhub Claude Code plugin — Korean-first NL deploy/manage for vibe coders. TypeScript helper layer (Bun runtime).",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build src/axhub-helpers/index.ts --compile --outfile bin/axhub-helpers --target=bun",
    "build:darwin-arm64": "bun build src/axhub-helpers/index.ts --compile --target=bun-darwin-arm64 --outfile bin/axhub-helpers-darwin-arm64",
    "build:darwin-amd64": "bun build src/axhub-helpers/index.ts --compile --target=bun-darwin-x64   --outfile bin/axhub-helpers-darwin-amd64",
    "build:linux-amd64": "bun build src/axhub-helpers/index.ts --compile --target=bun-linux-x64    --outfile bin/axhub-helpers-linux-amd64",
    "build:linux-arm64": "bun build src/axhub-helpers/index.ts --compile --target=bun-linux-arm64  --outfile bin/axhub-helpers-linux-arm64",
    "build:windows-amd64": "bun build src/axhub-helpers/index.ts --compile --target=bun-windows-x64  --outfile bin/axhub-helpers-windows-amd64.exe",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-amd64 && bun run build:linux-amd64 && bun run build:linux-arm64 && bun run build:windows-amd64",
    "smoke": "bun run build && ./bin/axhub-helpers version && ./bin/axhub-helpers help",
    "smoke:full": "bun run build && ./bin/axhub-helpers version && ./bin/axhub-helpers help && ./bin/axhub-helpers session-start </dev/null && bash tests/docs-link-audit.sh && bun run fuzz && bun run codegen:catalog && bun run codegen:version",
    "bench:hooks": "bun scripts/benchmark-hooks.ts",
    "codegen:catalog": "bun scripts/codegen-catalog.ts",
    "codegen:version": "bun scripts/codegen-install-version.ts",
    "lint:tone": "bun scripts/check-toss-tone-conformance.ts --strict",
    "lint:keywords": "bun scripts/check-skill-keywords-preserved.ts --check",
    "release:check": "bun scripts/release-check.ts",
    "release": "commit-and-tag-version",
    "skill:new": "bun scripts/skill-new.ts",
    "skill:doctor": "bun scripts/skill-doctor.ts",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e/",
    "test:plugin-e2e": "bash tests/e2e/claude-cli/run-matrix.sh",
    "test:plugin-e2e:t1": "bash tests/e2e/claude-cli/run-matrix.sh --tier t1",
    "test:plugin-e2e:t2": "bash tests/e2e/claude-cli/run-matrix.sh --tier t2",
    "test:plugin-e2e:nightly": "bash tests/e2e/claude-cli/run-matrix.sh --tier nightly",
    "typecheck": "tsc --noEmit",
    "fuzz": "bun tests/fuzz-parser.ts",
    "lint:tone:rust": "bun scripts/check-toss-tone-conformance.ts --include \"crates/**/*.rs\" --strict",
    "cargo:test": "cargo test --workspace",
    "cargo:build": "cargo build --workspace",
    "cargo:coverage": "cargo llvm-cov --workspace --fail-under-lines 90"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "semver": "^7.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/semver": "^7.5.8",
    "commit-and-tag-version": "^12.7.1",
    "typescript": "^5.6.3"
  }
}
